<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Exchange.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Exchange.App"
    xmlns:viewModels="clr-namespace:Exchange.App.ViewModels"
    xmlns:views="clr-namespace:Exchange.App.Views"
    x:DataType="viewModels:AppShellViewModel">



    <Shell.MenuBarItems>
        <MenuBarItem Text="File">
            <MenuFlyoutItem Command="{Binding ExitCommand}" Text="Exit">
                <MenuFlyoutItem.IconImageSource>
                    <FontImageSource
                        FontFamily="Arial"
                        Glyph="&#x25B6;"
                        Color="{AppThemeBinding Light=Black,
                                                Dark=White}" />
                </MenuFlyoutItem.IconImageSource>
            </MenuFlyoutItem>
        </MenuBarItem>

        <MenuBarItem Text="Exchange Rates">
            <MenuFlyoutItem Command="{Binding AddExchangeRateCommand}" Text="Add Exchange Rate">
                <MenuFlyoutItem.IconImageSource>
                    <FontImageSource
                        FontFamily="Arial"
                        Glyph="&#x25B6;"
                        Color="{AppThemeBinding Light=Black,
                                                Dark=White}" />
                </MenuFlyoutItem.IconImageSource>
            </MenuFlyoutItem>
            <MenuFlyoutItem Command="{Binding ListExchangeRatesCommand}" Text="List Exchange Rates">
                <MenuFlyoutItem.IconImageSource>
                    <FontImageSource
                        FontFamily="Arial"
                        Glyph="&#x25B6;"
                        Color="{AppThemeBinding Light=Black,
                                                Dark=White}" />
                </MenuFlyoutItem.IconImageSource>
            </MenuFlyoutItem>
            <MenuFlyoutItem Command="{Binding ExchangeRatesStatistics}" Text="Exchange Rates Statistics">
                <MenuFlyoutItem.IconImageSource>
                    <FontImageSource
                        FontFamily="Arial"
                        Glyph="&#x25B6;"
                        Color="{AppThemeBinding Light=Black,
                                                Dark=White}" />
                </MenuFlyoutItem.IconImageSource>
            </MenuFlyoutItem>
        </MenuBarItem>

        <MenuBarItem Text="Transactions">

            <MenuFlyoutItem Command="{Binding AddTransactionCommand}" Text="Add Transaction">
                <MenuFlyoutItem.IconImageSource>
                    <FontImageSource
                        FontFamily="Arial"
                        Glyph="&#x25B6;"
                        Color="{AppThemeBinding Light=Black,
                                                Dark=White}" />
                </MenuFlyoutItem.IconImageSource>
            </MenuFlyoutItem>

        </MenuBarItem>
    </Shell.MenuBarItems>

    <ShellContent ContentTemplate="{DataTemplate views:MainView}" Route="main" />

</Shell>
