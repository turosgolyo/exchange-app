<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Exchange.App.Views.ExchangeRateView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:viewModels="clr-namespace:Exchange.App.ViewModels"
    x:DataType="viewModels:ExchangeRateViewModel">

    <Grid BackgroundColor="#CCFFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="500" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="800" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Row="1"
            Grid.Column="1"
            Background="{StaticResource White}"
            Stroke="{StaticResource Primary}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,*" RowDefinitions="*, *, *, *, *, *">

                <Label
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="25,30,0,0"
                    FontAttributes="Bold"
                    FontSize="Large"
                    Text="{Binding FormTitle}" />
                <Border
                    Grid.Row="1"
                    Margin="20,0,0,0"
                    HeightRequest="40"
                    HorizontalOptions="Start"
                    Stroke="DimGray"
                    WidthRequest="150">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="5" />
                    </Border.StrokeShape>
                    <Label
                        Margin="15,0,0,0"
                        FontSize="Small"
                        Text="{Binding DateTimeNowString}"
                        VerticalOptions="Center" />
                </Border>

                <inputLayout:SfTextInputLayout
                    Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Margin="20,0,20,0"
                    ContainerType="Outlined"
                    ErrorText="{Binding ValidationResult, Converter={StaticResource ValidationResultToErrorMessagesConverter}, ConverterParameter=UsdtoHUF}"
                    HasError="{Binding ValidationResult, Converter={StaticResource ValidationResultHasErrorConverter}, ConverterParameter=UsdtoHUF}"
                    HeightRequest="80"
                    Hint="Usd to huf">
                    <Entry Text="{Binding UsdToHuf}" />
                </inputLayout:SfTextInputLayout>

                <inputLayout:SfTextInputLayout
                    Grid.Row="3"
                    Grid.ColumnSpan="2"
                    Margin="20,0,20,0"
                    ContainerType="Outlined"
                    ErrorText="{Binding ValidationResult, Converter={StaticResource ValidationResultToErrorMessagesConverter}, ConverterParameter=GbptoHUF}"
                    HasError="{Binding ValidationResult, Converter={StaticResource ValidationResultHasErrorConverter}, ConverterParameter=GbptoHUF}"
                    HeightRequest="80"
                    Hint="Gbp to huf">
                    <Entry Text="{Binding GbpToHuf}" />
                </inputLayout:SfTextInputLayout>

                <inputLayout:SfTextInputLayout
                    Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Margin="20,0,20,0"
                    ContainerType="Outlined"
                    ErrorText="{Binding ValidationResult, Converter={StaticResource ValidationResultToErrorMessagesConverter}, ConverterParameter=ChftoHUF}"
                    HasError="{Binding ValidationResult, Converter={StaticResource ValidationResultHasErrorConverter}, ConverterParameter=ChftoHUF}"
                    HeightRequest="80"
                    Hint="Chf to huf">
                    <Entry Text="{Binding ChfToHuf}" />
                </inputLayout:SfTextInputLayout>

                <Button
                    x:Name="saveRatesButton"
                    Grid.Row="5"
                    Grid.ColumnSpan="2"
                    Margin="20,0,20,20"
                    Padding="0"
                    Background="{StaticResource Primary}"
                    Command="{Binding SaveRatesCommand}"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    HeightRequest="40"
                    HorizontalOptions="Fill"
                    Text="Save rates"
                    VerticalOptions="End" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
